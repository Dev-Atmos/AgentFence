{
  "name": "agentfence",
  "version": "0.1.0",
  "description": "Developer-first security scanner for AI agents, MCP servers, and tool-connected LLM workflows.",
  "type": "module",
  "bin": {
    "agentfence": "./bin/agentfence.js"
  },
  "scripts": {
